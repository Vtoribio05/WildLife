@page "/mapa"
@rendermode InteractiveServer
@using WildlifeFrontend.Models
@using WildlifeFrontend.Services
@using WildlifeFrontend.Components.UI
@inject IWildlifeApiService ApiService

<PageTitle>Mapa - WildLife</PageTitle>

<div class="map-layout">
    <!-- Top Navigation Bar -->
    <div class="map-topbar">
        <a href="/" class="map-brand" title="Volver al inicio" id="btn-back-home">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            <span>WildLife</span>
        </a>

        <div class="filter-pills" id="filter-pills">
            <button class="filter-btn @(currentFilter == "Terrestres" ? "active" : "")" @onclick="@(() => Filter("Terrestres"))">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/>
                </svg>
                Terrestres
            </button>
            <button class="filter-btn @(currentFilter == "Marinos" ? "active" : "")" @onclick="@(() => Filter("Marinos"))">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 12h2a8 8 0 1 0 16 0h2"/>
                    <path d="M2 12c2-2 4-3 6-3s4 1 6 3c2 2 4 3 6 3"/>
                </svg>
                Marinos
            </button>
            <button class="filter-btn @(currentFilter == "Todos" ? "active" : "")" @onclick="@(() => Filter("Todos"))">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="2" y1="12" x2="22" y2="12"></line>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                </svg>
                Todos
            </button>
        </div>

        <div class="topbar-right">
            <div class="sighting-count">
                <span class="count-dot"></span>
                <span>@filteredAvistamientos.Count() avistamientos</span>
            </div>
        </div>
    </div>

    <!-- Map Component -->
    <WildlifeMap @ref="mapComponent" Avistamientos="filteredAvistamientos" />

    <!-- Chatbot Component -->
    <AiChatSidebar OnAnimalFound="HandleAnimalFound" />
</div>

@code {
    private IEnumerable<Avistamiento> allAvistamientos = new List<Avistamiento>();
    private IEnumerable<Avistamiento> filteredAvistamientos = new List<Avistamiento>();
    private WildlifeMap? mapComponent;
    private string currentFilter = "Todos";

    protected override async Task OnInitializedAsync()
    {
        var data = await ApiService.GetAvistamientosAsync();
        if (data != null)
        {
            allAvistamientos = data;
            filteredAvistamientos = allAvistamientos;
        }
    }

    private void Filter(string tipo)
    {
        currentFilter = tipo;
        if (tipo == "Todos")
        {
            filteredAvistamientos = allAvistamientos;
        }
        else if (tipo == "Marinos")
        {
            filteredAvistamientos = allAvistamientos.Where(a => IsMarino(a.Especie)).ToList();
        }
        else if (tipo == "Terrestres")
        {
            filteredAvistamientos = allAvistamientos.Where(a => !IsMarino(a.Especie)).ToList();
        }
    }

    private bool IsMarino(Especie? especie)
    {
        if (especie == null) return false;
        
        string nombre = especie.NombreComun.ToLower();
        return especie.Tipo == "Pez" || 
               nombre.Contains("ballena") || 
               nombre.Contains("delfín") || 
               nombre.Contains("tortuga") || 
               nombre.Contains("mantarraya") ||
               nombre.Contains("tiburón");
    }

    private async Task HandleAnimalFound(ChatbotResponse response)
    {
        if (mapComponent == null) return;
        
        // Primero intentamos buscarlo en nuestra base de datos
        var sighting = allAvistamientos.FirstOrDefault(a => 
            a.Especie != null && 
            !string.IsNullOrWhiteSpace(response.AnimalName) &&
            a.Especie.NombreComun.Contains(response.AnimalName, StringComparison.OrdinalIgnoreCase));
            
        if (sighting != null && sighting.Coordenadas != null)
        {
            // Focus on map
            double lat = sighting.Coordenadas.Coordinates[1];
            double lng = sighting.Coordenadas.Coordinates[0];
            await mapComponent.FlyToAsync(lng, lat);
        }
        else if (response.Longitude.HasValue && response.Latitude.HasValue)
        {
            // El animal no está en la base de datos, así que usamos el marcador dinámico de la IA
            string title = !string.IsNullOrWhiteSpace(response.AnimalName) ? response.AnimalName : "Animal desconocido";
            string desc = !string.IsNullOrWhiteSpace(response.Description) ? response.Description : "No hay descripción disponible.";
            string biome = !string.IsNullOrWhiteSpace(response.Biome) ? response.Biome : "Desconocido";
            string fotoUrl = !string.IsNullOrWhiteSpace(response.FotoUrl) ? response.FotoUrl : "";
            await mapComponent.AddDynamicMarkerAsync(response.Longitude.Value, response.Latitude.Value, title, desc, biome, fotoUrl);
        }
    }
}

<style>
    /* ===== MAP LAYOUT ===== */
    .map-layout {
        position: relative;
        width: 100vw;
        height: 100vh;
        overflow: hidden;
        background: #0a0b0d;
    }
    
    /* ===== TOP BAR ===== */
    .map-topbar {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        z-index: 10;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 24px;
        background: linear-gradient(180deg, rgba(10, 11, 13, 0.85) 0%, rgba(10, 11, 13, 0.4) 80%, transparent 100%);
        pointer-events: none;
    }
    
    .map-topbar > * {
        pointer-events: auto;
    }

    /* Brand / Back Button */
    .map-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: #f5c862;
        font-size: 1.15rem;
        font-weight: 700;
        background: rgba(10, 11, 13, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(245, 200, 98, 0.15);
        border-radius: 50px;
        padding: 10px 20px 10px 16px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .map-brand:hover {
        background: rgba(245, 200, 98, 0.1);
        border-color: rgba(245, 200, 98, 0.4);
        transform: translateX(-3px);
        box-shadow: 0 4px 20px rgba(245, 200, 98, 0.1);
    }
    
    .map-brand svg {
        transition: transform 0.3s ease;
    }
    
    .map-brand:hover svg {
        transform: translateX(-3px);
    }

    /* Filter Pills */
    .filter-pills {
        display: flex;
        background: rgba(10, 11, 13, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 50px;
        padding: 4px;
        gap: 2px;
    }
    
    .filter-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.6);
        padding: 9px 18px;
        border-radius: 50px;
        cursor: pointer;
        font-size: 0.88rem;
        font-weight: 500;
        font-family: inherit;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .filter-btn:hover {
        color: rgba(255, 255, 255, 0.9);
        background: rgba(255, 255, 255, 0.05);
    }
    
    .filter-btn.active {
        background: linear-gradient(135deg, #f5c862, #e8a838);
        color: #0a0b0d;
        font-weight: 700;
        box-shadow: 0 2px 12px rgba(245, 200, 98, 0.3);
    }
    
    .filter-btn.active svg {
        stroke: #0a0b0d;
    }

    /* Topbar Right */
    .topbar-right {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .sighting-count {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(10, 11, 13, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 50px;
        padding: 10px 18px;
        font-size: 0.85rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.7);
    }

    .count-dot {
        width: 8px;
        height: 8px;
        background: #10b981;
        border-radius: 50%;
        animation: pulse-dot 2s infinite;
    }

    @@keyframes pulse-dot {
        0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
        50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
    }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 768px) {
        .map-topbar {
            padding: 10px 12px;
            flex-wrap: wrap;
            gap: 8px;
        }

        .filter-pills {
            order: 3;
            width: 100%;
            justify-content: center;
        }

        .sighting-count {
            font-size: 0.78rem;
            padding: 8px 14px;
        }

        .map-brand span {
            display: none;
        }

        .map-brand {
            padding: 10px 14px;
        }
    }
</style>
