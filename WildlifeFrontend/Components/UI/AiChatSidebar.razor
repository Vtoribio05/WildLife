@using WildlifeFrontend.Services
@inject IWildlifeApiService ApiService

<div class="chat-panel @(isExpanded ? "expanded" : "collapsed")">
    <!-- Toggle Button -->
    <button class="chat-toggle" @onclick="ToggleChat" title="@(isExpanded ? "Cerrar chat" : "Abrir asistente IA")">
        @if (isExpanded)
        {
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        }
        else
        {
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
            <span class="toggle-label">IA</span>
        }
    </button>

    @if (isExpanded)
    {
        <!-- Header -->
        <div class="chat-head">
            <div class="chat-head-left">
                <div class="chat-avatar">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" stroke="#f5c862"/>
                        <path d="M8 14s1.5 2 4 2 4-2 4-2" stroke="#f5c862" stroke-linecap="round"/>
                        <circle cx="9" cy="10" r="1" fill="#f5c862"/>
                        <circle cx="15" cy="10" r="1" fill="#f5c862"/>
                    </svg>
                </div>
                <div>
                    <div class="chat-head-title">Asistente WildLife</div>
                    <div class="chat-head-sub">
                        <span class="online-dot"></span>
                        En línea
                    </div>
                </div>
            </div>
        </div>

        <!-- Messages -->
        <div class="chat-body">
            @foreach (var msg in Messages)
            {
                <div class="msg @(msg.IsUser ? "msg-user" : "msg-ai")">
                    @if (!msg.IsUser)
                    {
                        <div class="msg-ai-avatar">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f5c862" stroke-width="2">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
                            </svg>
                        </div>
                    }
                    <div class="msg-bubble">@msg.Text</div>
                </div>
            }
            @if (IsLoading)
            {
                <div class="msg msg-ai">
                    <div class="msg-ai-avatar">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f5c862" stroke-width="2">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
                        </svg>
                    </div>
                    <div class="msg-bubble typing">
                        <span class="dot"></span>
                        <span class="dot"></span>
                        <span class="dot"></span>
                    </div>
                </div>
            }
        </div>

        <!-- Input -->
        <div class="chat-foot">
            <div class="chat-input-wrap">
                <input type="text" @bind="InputMessage" @bind:event="oninput" @onkeyup="HandleKeyUp" 
                       placeholder="Pregunta sobre una especie..." 
                       class="chat-field" disabled="@IsLoading" id="chat-input" />
                <button class="chat-submit" @onclick="SendMessage" disabled="@(string.IsNullOrWhiteSpace(InputMessage) || IsLoading)" id="chat-send">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                    </svg>
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public EventCallback<ChatbotResponse> OnAnimalFound { get; set; }

    private string InputMessage = "";
    private bool IsLoading = false;
    private bool isExpanded = true;
    private List<ChatMessage> Messages = new()
    {
        new ChatMessage { IsUser = false, Text = "¡Hola! Soy tu asistente de vida silvestre. Pregúntame sobre cualquier especie y te la mostraré en el mapa. 🌍" }
    };

    private void ToggleChat()
    {
        isExpanded = !isExpanded;
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(InputMessage)) return;

        var userMsg = InputMessage;
        InputMessage = "";
        
        Messages.Add(new ChatMessage { IsUser = true, Text = userMsg });
        IsLoading = true;
        StateHasChanged();

        var aiResponse = await ApiService.SendChatMessageAsync(userMsg);
        
        Messages.Add(new ChatMessage { IsUser = false, Text = aiResponse.Answer });
        IsLoading = false;
        
        if (!string.IsNullOrWhiteSpace(aiResponse.AnimalName) && aiResponse.Longitude.HasValue && aiResponse.Latitude.HasValue)
        {
            await OnAnimalFound.InvokeAsync(aiResponse);
        }
    }

    private class ChatMessage
    {
        public bool IsUser { get; set; }
        public string Text { get; set; } = string.Empty;
    }
}

<style>
    /* ===== CHAT PANEL ===== */
    .chat-panel {
        position: absolute;
        right: 20px;
        top: 70px;
        bottom: 20px;
        z-index: 20;
        display: flex;
        flex-direction: column;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .chat-panel.expanded {
        width: 360px;
        background: rgba(10, 11, 13, 0.85);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    }

    .chat-panel.collapsed {
        width: auto;
        background: transparent;
        border: none;
        top: auto;
        bottom: 28px;
    }

    /* ===== TOGGLE BUTTON ===== */
    .chat-toggle {
        display: flex;
        align-items: center;
        gap: 6px;
        border: none;
        cursor: pointer;
        font-family: inherit;
        transition: all 0.3s ease;
    }

    .collapsed .chat-toggle {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        justify-content: center;
        background: linear-gradient(135deg, #f5c862, #e8a838);
        color: #0a0b0d;
        box-shadow: 0 4px 20px rgba(245, 200, 98, 0.35);
        padding: 0;
        position: relative;
    }

    .collapsed .chat-toggle:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 30px rgba(245, 200, 98, 0.5);
    }

    .toggle-label {
        display: none;
    }

    .expanded .chat-toggle {
        position: absolute;
        top: 16px;
        right: 16px;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        justify-content: center;
        background: rgba(255, 255, 255, 0.06);
        color: rgba(255, 255, 255, 0.5);
        padding: 0;
        z-index: 5;
    }

    .expanded .chat-toggle:hover {
        background: rgba(255, 255, 255, 0.12);
        color: white;
    }

    /* ===== HEADER ===== */
    .chat-head {
        padding: 20px 20px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .chat-head-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .chat-avatar {
        width: 40px;
        height: 40px;
        background: rgba(245, 200, 98, 0.1);
        border: 1px solid rgba(245, 200, 98, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .chat-head-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: #f0f0f0;
    }

    .chat-head-sub {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.78rem;
        color: #10b981;
        font-weight: 500;
        margin-top: 2px;
    }

    .online-dot {
        width: 6px;
        height: 6px;
        background: #10b981;
        border-radius: 50%;
    }

    /* ===== MESSAGES ===== */
    .chat-body {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.1) transparent;
    }

    .chat-body::-webkit-scrollbar {
        width: 4px;
    }

    .chat-body::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.1);
        border-radius: 4px;
    }

    .msg {
        display: flex;
        gap: 8px;
        max-width: 88%;
        animation: msgFadeIn 0.3s ease-out;
    }

    @@keyframes msgFadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .msg-user {
        align-self: flex-end;
        flex-direction: row-reverse;
    }

    .msg-ai {
        align-self: flex-start;
    }

    .msg-ai-avatar {
        width: 26px;
        height: 26px;
        min-width: 26px;
        background: rgba(245, 200, 98, 0.1);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-top: 2px;
    }

    .msg-bubble {
        padding: 10px 14px;
        border-radius: 14px;
        font-size: 0.88rem;
        line-height: 1.55;
    }

    .msg-user .msg-bubble {
        background: rgba(245, 200, 98, 0.12);
        border: 1px solid rgba(245, 200, 98, 0.2);
        color: #f0f0f0;
        border-bottom-right-radius: 4px;
    }

    .msg-ai .msg-bubble {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: rgba(255, 255, 255, 0.85);
        border-bottom-left-radius: 4px;
    }

    /* Typing animation */
    .typing {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 14px 18px;
    }

    .typing .dot {
        width: 7px;
        height: 7px;
        background: rgba(245, 200, 98, 0.5);
        border-radius: 50%;
        animation: typingBounce 1.4s infinite ease-in-out;
    }

    .typing .dot:nth-child(2) { animation-delay: 0.2s; }
    .typing .dot:nth-child(3) { animation-delay: 0.4s; }

    @@keyframes typingBounce {
        0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
        30% { transform: translateY(-6px); opacity: 1; }
    }

    /* ===== INPUT ===== */
    .chat-foot {
        padding: 14px 16px;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    .chat-input-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 14px;
        padding: 4px 4px 4px 16px;
        transition: border-color 0.3s ease;
    }

    .chat-input-wrap:focus-within {
        border-color: rgba(245, 200, 98, 0.3);
    }

    .chat-field {
        flex: 1;
        background: transparent;
        border: none;
        color: #f0f0f0;
        padding: 10px 0;
        outline: none;
        font-size: 0.88rem;
        font-family: inherit;
    }

    .chat-field::placeholder {
        color: rgba(255, 255, 255, 0.3);
    }

    .chat-submit {
        width: 40px;
        height: 40px;
        min-width: 40px;
        border-radius: 10px;
        border: none;
        background: linear-gradient(135deg, #f5c862, #e8a838);
        color: #0a0b0d;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .chat-submit:hover:not(:disabled) {
        transform: scale(1.05);
        box-shadow: 0 2px 12px rgba(245, 200, 98, 0.3);
    }

    .chat-submit:disabled {
        opacity: 0.3;
        cursor: not-allowed;
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.3);
    }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 640px) {
        .chat-panel.expanded {
            width: calc(100vw - 40px);
            right: 20px;
        }
    }
</style>
